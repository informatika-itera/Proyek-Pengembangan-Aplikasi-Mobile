CREATE TABLE Doa (
    id INTEGER NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    arabic TEXT NOT NULL,
    latin TEXT NOT NULL,
    translation TEXT NOT NULL,
    category TEXT NOT NULL
);

selectAllDoa:
SELECT * FROM Doa;

selectDoaByCategory:
SELECT * FROM Doa
WHERE category = ?;

insertDoa:
INSERT INTO Doa(
    id,
    title,
    arabic,
    latin,
    translation,
    category
)
VALUES (?, ?, ?, ?, ?, ?);
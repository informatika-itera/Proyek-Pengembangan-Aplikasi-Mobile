# local.properties.example
# ================================================
# COPY file ini menjadi `local.properties` di root project,
# kemudian isi nilai-nilai sesuai dengan environment Anda.
#
# JANGAN commit `local.properties` ke repository
# (sudah di-ignore lewat .gitignore).
# ================================================

# Android SDK location
# Android Studio akan mengisi ini secara otomatis saat sync pertama.
# Atau set manual sesuai lokasi SDK Anda:
#   - macOS  : sdk.dir=/Users/<USERNAME>/Library/Android/sdk
#   - Linux  : sdk.dir=/home/<USERNAME>/Android/Sdk
#   - Windows: sdk.dir=C\:\\Users\\<USERNAME>\\AppData\\Local\\Android\\Sdk
#sdk.dir=
